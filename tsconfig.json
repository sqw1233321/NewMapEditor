{
  "compilerOptions": {
    "module": "commonjs",
    "lib": [
      "es2015",
      "es2017",
      "dom"
    ],
    "target": "ES2017",
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "rootDir": "./assets",
    "outDir": "./temp/ts-build",
    "forceConsistentCasingInFileNames": true,
    "strictNullChecks": false
  },
  "exclude": [
    "node_modules",
    "library",
    "local",
    "temp",
    "build",
    "settings"
  ]
}